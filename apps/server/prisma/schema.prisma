generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id String @id @default(cuid())

  email    String @unique
  password String

  role UserRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]
}

model Task {
  id String @id @default(cuid())

  title       String
  description String?

  status TaskStatus @default(TODO)

  priority TaskPriority @default(MEDIUM)

  dueDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
  @@index([dueDate])
  @@index([priority])
}
